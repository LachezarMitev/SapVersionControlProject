<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="10" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.vcs.controller.LoginController">
    <Label text="Вход в системата" style="-fx-font-size: 18px;"/>
    <TextField fx:id="usernameField" promptText="Потребителско име" maxWidth="200"/>
    <PasswordField fx:id="passwordField" promptText="Парола" maxWidth="200"/>
    <Button text="Вход" onAction="#handleLogin" />
</VBox>