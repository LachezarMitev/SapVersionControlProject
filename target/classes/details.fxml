<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.vcs.controller.DocumentDetailController" spacing="10" style="-fx-padding: 15;">
    <Label fx:id="docTitleLabel" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <Label text="История на версиите:" />
    <TableView fx:id="versionsTable" prefHeight="150">
        <columns>
            <TableColumn text="№" fx:id="versionCol" prefWidth="50"/>
            <TableColumn text="Автор" fx:id="authorCol" prefWidth="100"/>
            <TableColumn text="Дата" fx:id="dateCol" prefWidth="150"/>
            <TableColumn text="Статус" fx:id="statusCol" prefWidth="100"/>
        </columns>
    </TableView>

    <HBox spacing="10">
        <Button fx:id="approveBtn" text="Одобри версия" onAction="#handleApprove" style="-fx-background-color: lightgreen;" visible="false"/>
        <Button fx:id="rejectBtn" text="Отхвърли версия" onAction="#handleReject" style="-fx-background-color: lightcoral;" visible="false"/>
        <Button fx:id="editBtn" text="Редактирай (Нова версия)" onAction="#handleEdit"/>
        <Button fx:id="saveBtn" text="Запази като Draft" onAction="#handleSave" visible="false" style="-fx-base: #3498db;"/>
        <Button text="Покажи съдържание" onAction="#handleShowContent"/>
        <Button text="Сравни с предишна" onAction="#handleCompare"/>
    </HBox>



    <HBox spacing="10" VBox.vgrow="ALWAYS">
        <TextArea fx:id="contentArea1" editable="false" promptText="Избрана версия..." HBox.hgrow="ALWAYS"/>
        <TextArea fx:id="contentArea2" editable="false" promptText="Предишна версия..." HBox.hgrow="ALWAYS"/>
        <TextArea fx:id="contentArea" VBox.vgrow="ALWAYS" editable="false" wrapText="true"/>
    </HBox>
</VBox>